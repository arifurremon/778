// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String               @id @default(uuid())
  email                String               @unique
  username             String?              @unique
  password             String?
  name                 String?
  mobile               String?
  location             String?
  profession           String?              @default("Not specified")
  dob                  String?
  profileImage         String?
  image                String?
  emailVerified        DateTime?
  nameChangeCount      Int                  @default(0)
  joinDate             String?
  isAdmin              Boolean              @default(false)
  
  // Security & Lifecycle
  resetToken           String?
  resetTokenExp        DateTime?
  emailToken           String?
  deletedAt            DateTime?

  // Status Flags
  isVerified           Boolean              @default(false)
  isSeller             Boolean              @default(false)
  isServiceProvider    Boolean              @default(false)
  
  // Registration States
  registrationStatus         RegistrationStatus @default(NONE)
  serviceRegistrationStatus  RegistrationStatus @default(NONE)
  verificationRequestStatus  RegistrationStatus @default(NONE)
  verificationReason         String?

  // UI / Privacy Settings
  showShopBadge        Boolean              @default(true)
  showExpertBadge      Boolean              @default(true)
  showFullAge          Boolean              @default(false)
  showBirthdayOnly     Boolean              @default(true)
  privacySettings      Json?                // Stores { mobile: 'Private', email: 'Neighbours', ... }

  // Relationships
  posts                Post[]
  comments             Comment[]
  activityLogs         ActivityLog[]
  auditLogs            AuditLog[]
  shop                 Shop?
  expertService        ExpertService?
  
  // Social Trust
  sentRequests         NeighbourConnection[] @relation("Sender")
  receivedRequests     NeighbourConnection[] @relation("Receiver")

  // NextAuth
  accounts             Account[]
  sessions             Session[]

  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([createdAt])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model NeighbourConnection {
  id          String           @id @default(uuid())
  senderId    String
  sender      User             @relation("Sender", fields: [senderId], references: [id])
  receiverId  String
  receiver    User             @relation("Receiver", fields: [receiverId], references: [id])
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([senderId, receiverId])
}

model Post {
  id               String       @id @default(uuid())
  authorId         String
  author           User         @relation(fields: [authorId], references: [id])
  content          String
  images           String[]
  checkInLocation  String?
  visibility       PrivacyLevel @default(PUBLIC)
  helpfulCount     Int          @default(0)
  notHelpfulCount  Int          @default(0)
  comments         Comment[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([visibility])
  @@index([authorId])
  @@index([createdAt])
}

model Comment {
  id          String   @id @default(uuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  text        String
  likes       Int      @default(0)
  unlikes     Int      @default(0)
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  type        ActivityType
  description String
  contextUrl  String?
  isRead      Boolean      @default(false)
  createdAt   DateTime     @default(now())
}

model Shop {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id])
  name              String
  description       String
  category          String
  location          String
  trustScore        Int                @default(100)
  rating            Float              @default(5.0)
  isVerified        Boolean            @default(false)
  products          Product[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([userId])
}

model Product {
  id             String   @id @default(uuid())
  shopId         String
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name           String
  description    String
  price          String
  originalPrice  String?
  images         String[]
  inStock        Boolean  @default(true)
  category       String
  createdAt      DateTime @default(now())
}

model ExpertService {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  profession      String
  category        String
  location        String
  experienceYears Int      @default(0)
  fee             String
  bio             String
  qualifications  String[]
  rating          Float    @default(5.0)
  createdAt       DateTime @default(now())
}

enum RegistrationStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum PrivacyLevel {
  PUBLIC
  NEIGHBOURS
  PRIVATE
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum ActivityType {
  LIKE
  COMMENT
  SAVED
  SYSTEM
  POPULAR
}

// -----------------------------------------------------------------------------
// INSTRUCTION: Run `npx prisma migrate dev --name add_admin_settings_audit` 
// to apply these new schema models to the database.
// -----------------------------------------------------------------------------

model Settings {
  id                    String   @id @default("global")
  siteName              String   @default("The Chattala")
  siteDescription       String   @default("A hyper-local community platform")
  contactEmail          String   @default("support@thechattala.com")
  supportPhone          String   @default("")
  maintenanceMode       Boolean  @default(false)
  registrationOpen      Boolean  @default(true)
  emailVerificationReq  Boolean  @default(true)
  featuresEnabled       Json     @default("{}")
  defaultPostVisibility String   @default("PUBLIC")
  updatedAt             DateTime @updatedAt
  updatedBy             String?
}

model AuditLog {
  id          String   @id @default(uuid())
  adminId     String
  admin       User     @relation(fields: [adminId], references: [id])
  action      String
  entityType  String
  entityId    String
  details     Json     @default("{}")
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

