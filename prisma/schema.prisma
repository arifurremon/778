// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id                   String               @id @default(uuid())
  email                String               @unique
  username             String?              @unique
  password             String?
  name                 String?
  preferredName        String?
  mobile               String?
  location             String?
  profession           String?              @default("Not specified")
  bio                  String?
  dob                  String?
  profileImage         String?
  image                String?
  emailVerified        DateTime?
  nameChangeCount      Int                  @default(0)
  joinDate             String?
  isAdmin              Boolean              @default(false)
  
  // Security & Lifecycle
  resetToken           String?
  resetTokenExp        DateTime?
  emailToken           String?
  emailTokenExp        DateTime?
  deletedAt            DateTime?

  // Status Flags
  isVerified           Boolean              @default(false)
  isSeller             Boolean              @default(false)
  isServiceProvider    Boolean              @default(false)
  
  // Registration States
  registrationStatus         RegistrationStatus @default(NONE)
  serviceRegistrationStatus  RegistrationStatus @default(NONE)
  verificationRequestStatus  RegistrationStatus @default(NONE)
  verificationReason         String?

  // UI / Privacy Settings
  showShopBadge        Boolean              @default(true)
  showExpertBadge      Boolean              @default(true)
  showFullAge          Boolean              @default(false)
  showBirthdayOnly     Boolean              @default(true)
  privacySettings      Json?                // Stores { mobile: 'Private', email: 'Neighbours', ... }

  // Relationships
  posts                Post[]
  comments             Comment[]
  activityLogs         ActivityLog[]
  auditLogs            AuditLog[]
  shop                 Shop?
  expertService        ExpertService?
  postReactions        UserPostReaction[]
  commentReactions     UserCommentReaction[]
  orders               Order[]
  
  // Social Trust
  sentRequests         NeighbourConnection[] @relation("Sender")
  receivedRequests     NeighbourConnection[] @relation("Receiver")
  blockedUsers         BlockedUser[]         @relation("BlockerList")
  blockedBy            BlockedUser[]         @relation("BlockedList")

  // Notifications
  notifications        Notification[]        @relation("NotificationRecipient")
  triggeredNotifications Notification[]      @relation("NotificationActor")

  // Messaging
  conversationsAsA     Conversation[] @relation("ConversationUserA")
  conversationsAsB     Conversation[] @relation("ConversationUserB")
  messagesSent         Message[]

  // NextAuth
  accounts             Account[]
  sessions             Session[]

  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([createdAt])
  @@index([emailToken, emailTokenExp])
  @@index([resetToken, resetTokenExp])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model NeighbourConnection {
  id          String           @id @default(uuid())
  senderId    String
  sender      User             @relation("Sender", fields: [senderId], references: [id])
  receiverId  String
  receiver    User             @relation("Receiver", fields: [receiverId], references: [id])
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([senderId, receiverId])
}

// ---------------------------------------------------------------------------
// Notification
//
// A single, centralised notification row covering every event type across
// every module (Community, Connections, E-commerce, Services, Admin).
//
// Design principles:
//
//   1. Polymorphic entity reference via (entityType + entityId).
//      Foreign-key constraints are intentionally omitted on these two fields
//      because a notification may point to any table (Post, Comment, Order,
//      NeighbourConnection, Shop, ExpertService, User, …). Enforcing a hard FK
//      would require a separate junction table per entity type, which adds
//      schema complexity without practical benefit — the application layer
//      is responsible for writing valid IDs.
//
//   2. Optional actorId. System-generated events (SYSTEM_ALERT,
//      MODERATION_ACTION) have no human actor. The field is nullable to
//      accommodate both human-triggered and system-triggered events without
//      a sentinel value.
//
//   3. JSON metadata field for type-specific payloads. Each NotificationType
//      may need different contextual data that does not belong in dedicated
//      columns (e.g., reaction emoji for POST_REACTION, old/new status for
//      ORDER_UPDATED, rejection reason for SHOP_VERIFIED). The metadata field
//      holds a typed JSON blob. Application code is responsible for reading
//      and writing this field with the correct shape for each type.
//
//   4. Indexed for the two read patterns that matter:
//      • userId + isRead  → unread badge count query (O(1) with index)
//      • userId + createdAt → chronological inbox query (covering index)
// ---------------------------------------------------------------------------
model Notification {
  id          String           @id @default(uuid())

  // Recipient — the user who should see this notification
  userId      String
  user        User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  // Actor — the user who triggered the event (null for system events)
  actorId     String?
  actor       User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  // What happened
  type        NotificationType

  // Polymorphic entity reference
  // entityType: the logical name of the source table ("Post", "Comment",
  //             "Order", "NeighbourConnection", "Shop", "ExpertService").
  // entityId:   the UUID primary key of the referenced row.
  // Both are nullable because SYSTEM_ALERT notifications may not reference
  // any specific entity.
  entityType  String?
  entityId    String?

  // Type-specific contextual payload.
  // Examples:
  //   POST_REACTION:  { "emoji": "👍", "postPreview": "Great news about..." }
  //   ORDER_UPDATED:  { "oldStatus": "PENDING", "newStatus": "CONFIRMED" }
  //   SHOP_VERIFIED:  { "approved": true }
  //   NEW_COMMENT:    { "commentPreview": "Great point! I also think..." }
  //   SYSTEM_ALERT:   { "message": "Your account was flagged for review." }
  metadata    Json             @default("{}")

  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  // Covering index for the inbox query: fetch all notifications for a user
  // ordered by recency. Postgres can satisfy ORDER BY createdAt DESC with
  // this index without a separate sort step.
  @@index([userId, createdAt])

  // Partial-style index for the unread badge count query:
  // SELECT COUNT(*) WHERE userId = ? AND isRead = false
  @@index([userId, isRead])
}

model Post {
  id               String       @id @default(uuid())
  authorId         String
  author           User         @relation(fields: [authorId], references: [id])
  content          String
  images           String[]
  checkInLocation  String?
  visibility       PrivacyLevel @default(PUBLIC)
  helpfulCount     Int          @default(0)
  notHelpfulCount  Int          @default(0)
  flagged          Boolean      @default(false)
  moderationStatus String       @default("APPROVED")
  comments         Comment[]
  reactions        UserPostReaction[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([visibility])
  @@index([authorId])
  @@index([createdAt])
  @@index([flagged])
}

model Comment {
  id          String   @id @default(uuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  text        String
  likes       Int      @default(0)
  unlikes     Int      @default(0)
  createdAt   DateTime @default(now())
  reactions   UserCommentReaction[]
}

model ActivityLog {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  type        ActivityType
  description String
  contextUrl  String?
  isRead      Boolean      @default(false)
  createdAt   DateTime     @default(now())
}

model Shop {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id])
  name              String
  description       String
  category          String
  location          String
  trustScore        Int                @default(100)
  rating            Float              @default(5.0)
  isVerified        Boolean            @default(false)
  verifiedAt        DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?
  products          Product[]
  orders            Order[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([userId])
}

model Product {
  id             String   @id @default(uuid())
  shopId         String
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name           String
  description    String
  price          Decimal   @db.Decimal(10, 2)
  originalPrice  Decimal?  @db.Decimal(10, 2)
  images         String[]
  inStock        Boolean  @default(true)
  category       String
  createdAt      DateTime @default(now())
  orders         Order[]
}

model ExpertService {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  profession      String
  category        String
  location        String
  experienceYears Int      @default(0)
  fee             String
  bio             String
  qualifications  String[]
  rating          Float    @default(5.0)
  isVerified      Boolean  @default(false)
  verifiedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime @default(now())
}

enum RegistrationStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum PrivacyLevel {
  PUBLIC
  NEIGHBOURS
  PRIVATE
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum ActivityType {
  LIKE
  COMMENT
  SAVED
  SYSTEM
  POPULAR
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  COMMENT_LIKE
  COMMENT_DISLIKE
  POST_DISLIKE
}

// ---------------------------------------------------------------------------
// NotificationType
//
// Exhaustive enum covering every cross-module event that may produce a
// user-facing notification. Grouped by source module for readability.
// ---------------------------------------------------------------------------
enum NotificationType {
  // --- Community ---
  POST_REACTION        // Someone reacted to your post
  NEW_COMMENT          // Someone commented on your post
  COMMENT_REPLY        // Someone replied to your comment
  POST_FLAGGED         // A moderator flagged your post

  // --- Connections ---
  NEIGHBOR_REQUEST     // Someone sent you a neighbour request
  NEIGHBOR_ACCEPTED    // Your neighbour request was accepted

  // --- E-commerce (Shop) ---
  NEW_ORDER            // A buyer placed an order on your shop
  ORDER_UPDATED        // The status of an order changed
  SHOP_VERIFIED        // Your shop application was approved or rejected
  NEW_PRODUCT_REVIEW   // A buyer left a review on your product

  // --- Service Directory ---
  SERVICE_BOOKED       // Someone booked your expert service
  SERVICE_UPDATED      // A service booking status changed
  SERVICE_VERIFIED     // Your expert profile was approved or rejected

  // --- Admin / System ---
  SYSTEM_ALERT         // Platform-wide or account-targeted system message
  MODERATION_ACTION    // An admin took action on your content or account
}

// -----------------------------------------------------------------------------
// INSTRUCTION: Run `npx prisma migrate dev --name add_admin_settings_audit` 
// to apply these new schema models to the database.
// -----------------------------------------------------------------------------

model Settings {
  id                    String   @id @default("global")
  siteName              String   @default("The Chattala")
  siteDescription       String   @default("A hyper-local community platform")
  contactEmail          String   @default("support@thechattala.com")
  supportPhone          String   @default("")
  maintenanceMode       Boolean  @default(false)
  registrationOpen      Boolean  @default(true)
  emailVerificationReq  Boolean  @default(true)
  featuresEnabled       Json     @default("{}")
  defaultPostVisibility String   @default("PUBLIC")
  updatedAt             DateTime @updatedAt
  updatedBy             String?
}

model AuditLog {
  id          String   @id @default(uuid())
  adminId     String
  admin       User     @relation(fields: [adminId], references: [id])
  action      String
  entityType  String
  entityId    String
  details     Json     @default("{}")
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

model Conversation {
  id           String    @id @default(uuid())
  participantA String
  participantB String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userA        User      @relation("ConversationUserA", fields: [participantA], references: [id], onDelete: Cascade)
  userB        User      @relation("ConversationUserB", fields: [participantB], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([participantA, participantB])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  text           String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

enum OrderStatus {
  PENDING
  PROCESSING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  REJECTED
}

model Order {
  id          String      @id @default(uuid())
  shopId      String
  shop        Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  productId   String
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyerId     String
  buyer       User        @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  buyerName   String?
  buyerPhone  String?
  status      OrderStatus @default(PENDING)
  quantity    Int         @default(1)
  totalPrice  Decimal     @db.Decimal(10, 2)
  address     String
  note        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([shopId])
  @@index([buyerId])
}

model BlockedUser {
  blockerId  String
  blockedId  String
  blocker    User     @relation("BlockerList", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked    User     @relation("BlockedList", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([blockerId, blockedId])
}

model UserPostReaction {
  userId    String
  postId    String
  type      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, postId])
}

model UserCommentReaction {
  userId    String
  commentId String
  type      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, commentId])
}
