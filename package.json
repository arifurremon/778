{
  "name": "thechattala",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 9002",
    "build": "next build",
    "build:ci": "npx prisma generate && npm run migrate:deploy && npm run build",
    "build:vercel": "npx prisma generate && npm run migrate:deploy && npm run build",
    "migrate:deploy": "bash scripts/migrate-deploy.sh",
    "start": "next start",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run test",
    "prepare": "node -e \"if(process.env.VERCEL||process.env.CI)process.exit(0)\" || husky",
    "postinstall": "node -e \"if(process.env.VERCEL)process.exit(0);require('child_process').execSync('npx prisma generate',{stdio:'inherit'})\"",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run src/__tests__/api",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install --with-deps chromium",
    "seed:phase3": "tsx scripts/seed-phase3-content.ts",
    "seed:staging": "tsx scripts/seed-staging.ts",
    "migrate:verify-fresh": "bash scripts/verify-fresh-migrate.sh",
    "drill:smoke": "tsx scripts/dr-drill-smoke.ts",
