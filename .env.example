# =============================================================================
# THE CHATTALA — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your own values.
#
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL — Serverless)
# Neon provides two URLs: a POOLED one for app queries and a DIRECT one for
# Prisma migrations. Both are required.
# Get them at: https://console.neon.tech
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"


# -----------------------------------------------------------------------------
# NextAuth / Auth.js v5
# AUTH_SECRET: Generate with: openssl rand -base64 32
# NEXTAUTH_URL: Full URL of your app (no trailing slash)
# -----------------------------------------------------------------------------
AUTH_SECRET="generated-secret-key-minimum-32-characters-long"
NEXTAUTH_SECRET="another-secret-minimum-32-characters"
NEXTAUTH_URL="http://localhost:9002"


# -----------------------------------------------------------------------------
# OAuth — Google Provider
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:9002/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret"


# -----------------------------------------------------------------------------
# File Uploads — UploadThing
# Get your keys at: https://uploadthing.com/dashboard
# -----------------------------------------------------------------------------
UPLOADTHING_SECRET="sk_live_your-uploadthing-secret"
UPLOADTHING_APP_ID="your-uploadthing-app-id"


# -----------------------------------------------------------------------------
# Redis / Rate Limiting — Upstash
# Used by @upstash/ratelimit for API rate limiting.
# Get your keys at: https://console.upstash.com
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL="https://your-redis-id.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-rest-token"


# -----------------------------------------------------------------------------
# Email Service — SMTP (Brevo / Resend / any SMTP provider)
# Used for: verification emails, password reset, notifications.
# -----------------------------------------------------------------------------
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-username@smtp-brevo.com"
SMTP_PASSWORD="your-smtp-api-key-or-password"
SMTP_FROM="hello@thechattala.com"


# -----------------------------------------------------------------------------
# Error Monitoring — Sentry
# Create a Next.js project at: https://sentry.io
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN="https://your-key@sentry.io/your-project-id"


# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV="development"
