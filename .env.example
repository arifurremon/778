# =============================================================================
# THE CHATTALA — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your own values.
#
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL — Serverless)
# Neon provides two URLs: a POOLED one for app queries and a DIRECT one for
# Prisma migrations. Both are required.
# Get them at: https://console.neon.tech
# -----------------------------------------------------------------------------
DATABASE_URL="your_database_url_here"
DIRECT_URL="your_direct_url_here"


# -----------------------------------------------------------------------------
# NextAuth / Auth.js v5
# AUTH_SECRET: Generate with: openssl rand -base64 32
# NEXTAUTH_URL: Full URL of your app (no trailing slash)
# -----------------------------------------------------------------------------
AUTH_SECRET="generate_a_secure_secret_key"
NEXTAUTH_SECRET="generate_a_secure_secret_key"
NEXTAUTH_URL="https://thechattala.com"

# NEXT_PUBLIC_APP_URL: Public URL of the application, used for absolute email links (e.g. registration/password resets) and CSRF verification.
# WARNING: This MUST match the production domain exactly with no trailing slash.
NEXT_PUBLIC_APP_URL="https://thechattala.com"


# -----------------------------------------------------------------------------
# Admin Settings (Optional — for Prisma seed)
# Used when seeding the database with initial admin user.
# If not provided, the seed script uses default values.
# Generate a strong password: openssl rand -base64 16
# -----------------------------------------------------------------------------
ADMIN_EMAIL="admin@thechattala.com"
ADMIN_PASSWORD="your_secure_admin_password"


# -----------------------------------------------------------------------------
# OAuth — Google Provider
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:9002/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"


# -----------------------------------------------------------------------------
# File Uploads — UploadThing
# Get your keys at: https://uploadthing.com/dashboard
# -----------------------------------------------------------------------------
UPLOADTHING_SECRET="your_uploadthing_secret"
UPLOADTHING_APP_ID="your_uploadthing_app_id"


# -----------------------------------------------------------------------------
# Redis / Rate Limiting — Upstash
# Used by @upstash/ratelimit for API rate limiting.
# Get your keys at: https://console.upstash.com
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL="your_upstash_redis_url"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token"


# -----------------------------------------------------------------------------
# Email Service — SMTP (Brevo / Resend / any SMTP provider)
# Used for: verification emails, password reset, notifications.
# -----------------------------------------------------------------------------
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER="aa0dcf001@smtp-brevo.com"
SMTP_PASSWORD="your_smtp_password"
SMTP_FROM="hello@thechattala.com"


# -----------------------------------------------------------------------------
# Error Monitoring — Sentry
# Create a Next.js project at: https://sentry.io
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN="your_sentry_dsn"


# -----------------------------------------------------------------------------
# Real-Time Notifications — Pusher Channels
# Create an app at: https://dashboard.pusher.com
# Select a cluster close to your users (e.g. ap2 for South/Southeast Asia).
# NEXT_PUBLIC_* variables are safe to expose to the browser.
# PUSHER_APP_ID and PUSHER_SECRET must NEVER be exposed to the browser.
# -----------------------------------------------------------------------------
PUSHER_APP_ID=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""


# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV="production"
