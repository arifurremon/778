# =============================================================================
# THE CHATTALA — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your own values.
#
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL — Serverless)
# Neon provides two URLs: a POOLED one for app queries and a DIRECT one for
# Prisma migrations. Both are required.
# Get them at: https://console.neon.tech
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"


# -----------------------------------------------------------------------------
# NextAuth / Auth.js v5
# AUTH_SECRET: Generate with: openssl rand -base64 32
# NEXTAUTH_URL: Full URL of your app (no trailing slash)
# -----------------------------------------------------------------------------
AUTH_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://thechattala.com"


# -----------------------------------------------------------------------------
# Admin Settings (Optional — for Prisma seed)
# Used when seeding the database with initial admin user.
# Generate a strong password: openssl rand -base64 16
# -----------------------------------------------------------------------------
ADMIN_EMAIL="admin@thechattala.com"
ADMIN_PASSWORD=""


# -----------------------------------------------------------------------------
# OAuth — Google Provider
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:9002/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""


# -----------------------------------------------------------------------------
# File Uploads — UploadThing
# Get your keys at: https://uploadthing.com/dashboard
# -----------------------------------------------------------------------------
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""


# -----------------------------------------------------------------------------
# Redis / Rate Limiting — Upstash
# Used by @upstash/ratelimit for API rate limiting.
# Get your keys at: https://console.upstash.com
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# -----------------------------------------------------------------------------
# Email Service — SMTP (Brevo / Resend / any SMTP provider)
# Used for: verification emails, password reset, notifications.
# -----------------------------------------------------------------------------
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="hello@thechattala.com"


# -----------------------------------------------------------------------------
# Error Monitoring — Sentry
# Create a Next.js project at: https://sentry.io
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""


# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV="production"
