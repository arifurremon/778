# =============================================================================
# THE CHATTALA — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your own values.
#
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL — Serverless)
# Neon provides two URLs: a POOLED one for app queries and a DIRECT one for
# Prisma migrations. Both are required.
# Get them at: https://console.neon.tech
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"


# -----------------------------------------------------------------------------
# CI / CodeQL (GitHub Actions — optional)
# After enabling Code scanning on the repo, set repository variable:
#   CODEQL_UPLOAD_SARIF=true
# so CodeQL SARIF results upload to the Security tab.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# NextAuth / Auth.js v5
# AUTH_SECRET: Generate with: openssl rand -base64 32
# NEXTAUTH_URL: Full URL of your deployed app (no trailing slash)
# NEXT_PUBLIC_APP_URL: Must match NEXTAUTH_URL exactly. Used by auth API
#   routes to build absolute URLs in transactional emails
#   (email verification, password reset). Without this,
#   all email links point to the wrong domain in production.
# -----------------------------------------------------------------------------
AUTH_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://thechattala.com"
NEXT_PUBLIC_APP_URL="https://thechattala.com"


# -----------------------------------------------------------------------------
# Admin Settings (Optional — for Prisma seed)
# Used when seeding the database with initial admin user.
# Generate a strong password: openssl rand -base64 16
# -----------------------------------------------------------------------------
ADMIN_EMAIL="admin@thechattala.com"
ADMIN_PASSWORD=""


# -----------------------------------------------------------------------------
# OAuth — Google Provider (OPTIONAL)
# Credentials + password is always available; Google is registered when both vars below are set.
# Set NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true to show the Google button in login/signup UI.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=""


# -----------------------------------------------------------------------------
# File Uploads — UploadThing
# Get your keys at: https://uploadthing.com/dashboard
# -----------------------------------------------------------------------------
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""


# -----------------------------------------------------------------------------
# Redis / Rate Limiting — Upstash
# Used by @upstash/ratelimit for API rate limiting.
# Get your keys at: https://console.upstash.com
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# -----------------------------------------------------------------------------
# Real-time Messaging — Pusher Channels
# Required for live notifications and chat features.
# Create a Channels app at: https://dashboard.pusher.com
# Use the "pusher-js" client library version for the frontend.
# Note: ap2 (Asia Pacific — Singapore) is the recommended cluster for Bangladesh users.
# -----------------------------------------------------------------------------
PUSHER_APP_ID=""
NEXT_PUBLIC_PUSHER_KEY=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"


# -----------------------------------------------------------------------------
# Email Service — SMTP (Brevo / Resend / any SMTP provider)
# Used for: verification emails, password reset, notifications.
# -----------------------------------------------------------------------------
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="hello@thechattala.com"


# -----------------------------------------------------------------------------
# Email branding
# Logo URL used in transactional email templates (also served from app domain)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_LOGO_URL="https://thechattala.com/logo-full.png"


# -----------------------------------------------------------------------------
# Error Monitoring — Sentry
# Create a Next.js project at: https://sentry.io
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""


# -----------------------------------------------------------------------------
# Background jobs — Inngest (Phase 7)
# Create a free app at https://www.inngest.com and sync with /api/inngest
# -----------------------------------------------------------------------------
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Feature flags (Phase 7) — set to "true" / "false" to override defaults
FEATURE_ASYNC_JOBS=""
FEATURE_ASYNC_MAIL=""
FEATURE_ASYNC_BULK_MESSAGE=""
FEATURE_ASYNC_EXPORT=""
FEATURE_ASYNC_RETENTION=""
FEATURE_CACHE_DIRECTORY=""
FEATURE_CACHE_EMERGENCY=""

# Cron auth for /api/cron/* (data-retention, webhook-retry)
CRON_SECRET=""


# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV="production"
